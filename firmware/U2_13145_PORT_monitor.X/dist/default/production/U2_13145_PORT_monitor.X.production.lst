  7648                           ;	PWRTS = PWRT_OFF, PWRT is disabled
  7649                           ;	Low-Power BOR Enable bit
  7650                           ;	LPBOREN = OFF, ULPBOR disabled
  7651                           ;	Brown-out Reset Enable bits
  7652                           ;	BOREN = ON, Brown-out Reset enabled, SBOREN bit is ignored
  7653                           ;	DAC Buffer Automatic Range Select Enable bit
  7654                           ;	DACAUTOEN = OFF, DAC Buffer reference range is determined by the REFRNG bit
  7655                           ;	Brown-out Reset Voltage Selection bit
  7656                           ;	BORV = LO, Brown-out Reset Voltage (VBOR) set to 1.9V
  7657                           ;	PPSLOCKED One-Way Set Enable bit
  7658                           ;	PPS1WAY = ON, The PPSLOCKED bit can be cleared and set only once after an unlocking se
      +                          quence is executed; once PPSLOCKED is set, all future changes to PPS registers are preve
      +                          nted
  7659                           ;	Stack Overflow/Underflow Reset Enable bit
  7660                           ;	STVREN = ON, Stack Overflow or Underflow will cause a reset
  7661                           ;	Background Debugger
  7662                           ;	DEBUG = 0x1, unprogrammed default
  7663     8008                     	org	32776
  7664     8008  3FFF               	dw	16383
  7665                           
  7666                           ;Config register CONFIG3 @ 0x8009
  7667                           ;	WDT Period Select bits
  7668                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
  7669                           ;	WDT Operating Mode bits
  7670                           ;	WDTE = OFF, WDT Disabled, SEN is ignored
  7671                           ;	WDT Window Select bits
  7672                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
  7673                           ;	WDT Input Clock Select bits
  7674                           ;	WDTCCS = SC, Software Control
  7675     8009                     	org	32777
  7676     8009  3F9F               	dw	16287
  7677                           
  7678                           ;Config register CONFIG4 @ 0x800A
  7679                           ;	Boot Block Size Selection bits
  7680                           ;	BBSIZE = BB512, 512 words boot block size
  7681                           ;	Boot Block Enable bit
  7682                           ;	BBEN = OFF, Boot Block disabled
  7683                           ;	Storage Area Flash (SAF) Enable bit
  7684                           ;	SAFEN = OFF, SAF disabled
  7685                           ;	Application Block Write Protection bit
  7686                           ;	WRTAPP = OFF, Application Block is NOT write-protected
  7687                           ;	Boot Block Write Protection bit
  7688                           ;	WRTB = OFF, Boot Block is NOT write-protected
  7689                           ;	Configuration Register Write Protection bit
  7690                           ;	WRTC = OFF, Configuration Register is NOT write-protected
  7691                           ;	Storage Area Flash (SAF) Write Protection bit
  7692                           ;	WRTSAF = OFF, SAF is NOT write-protected
  7693                           ;	Low Voltage Programming Enable bit
  7694                           ;	LVP = ON, Low Voltage programming enabled. MCLR/Vpp pin function is MCLR. MCLRE Config
      +                          uration bit is ignored
  7695     800A                     	org	32778
  7696     800A  3FFF               	dw	16383
  7697                           
  7698                           ;Config register CONFIG5 @ 0x800B
  7699                           ;	Program Flash Memory Code Protection bit
  7700                           ;	CP = OFF, Program Flash Memory code protection is disabled
  7701     800B                     	org	32779
  7702     800B  3FFF               	dw	16383

